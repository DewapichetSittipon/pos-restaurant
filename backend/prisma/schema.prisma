// Prisma schema สำหรับระบบ POS ร้านอาหาร + QR ordering (multi-tenant SaaS)
// ดูคำอธิบายโมเดลที่ ../../CONTEXT.md และเหตุผลที่ ../../docs/adr/
// เงินทั้งหมดเก็บเป็น Int หน่วย "สตางค์" (เลี่ยง float rounding)
// Multi-tenant: ทุก entity หลักผูกกับ Shop ด้วย shop_id — query ฝั่งพนักงาน scope ด้วย staff.shopId
// ฝั่งลูกค้า scope ด้วย bill.shopId (resolve จาก qr_token)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TableStatus {
  vacant
  occupied
}

enum BillStatus {
  pending
  paid
  refunded // เคย paid แล้วถูกคืนเงิน (ไม่นับเป็นยอดขาย)
}

enum PaymentMethod {
  cash
  transfer
}

// OrderItem ใช้ queued (ไม่ใช่ pending) เพื่อเลี่ยงชนกับ BillStatus.pending
enum OrderItemStatus {
  queued
  cooking
  served
  voided
}

enum ServiceRequestType {
  call_staff
  call_bill
}

enum ServiceRequestStatus {
  pending
  acknowledged
}

// สถานะร้าน: pending = สมัครเองรออนุมัติ (login ได้แต่ใช้งานไม่ได้), active = เปิดใช้งานแล้ว
enum ShopStatus {
  pending
  active
}

// สถานะกะขาย (cash drawer): open = กำลังเปิดอยู่, closed = ปิดและกระทบยอดแล้ว
// หนึ่งร้านมีกะ open ได้ทีละหนึ่ง (บังคับใน application logic)
enum ShiftStatus {
  open
  closed
}

// สถานะการจองโต๊ะ: booked = จองไว้, seated = ลูกค้ามาถึง/นั่งแล้ว, cancelled = ยกเลิก/ไม่มา
enum ReservationStatus {
  booked
  seated
  cancelled
}

// ประเภทออเดอร์: dine_in = ทานที่ร้าน (ผูกโต๊ะ), takeaway = กลับบ้าน, delivery = ส่งเดลิเวอรี
// takeaway/delivery ไม่ผูกโต๊ะ (table_id = null) และเก็บข้อมูลลูกค้า
enum OrderType {
  dine_in
  takeaway
  delivery
}

// ชนิดของโปรโมชัน (rule-based discount): คิดส่วนลดต่างกันตาม type
// percent  = ลด % ของยอด (value = basis points, 1000 = 10%); จำกัดเพดานได้ด้วย maxDiscount
// amount   = ลดเป็นจำนวนเงินคงที่ (value = สตางค์)
// bogo     = ซื้อครบ buyQty แถม getQty (ส่วนลด = ราคารวมชิ้นที่ถูกที่สุด getQty ชิ้นต่อรอบ)
enum PromotionType {
  percent
  amount
  bogo
}

// บทบาทพนักงานภายในร้าน — กำหนดว่าเห็น/ทำอะไรได้บ้าง
// OWNER = เจ้าของร้าน เห็นทุกอย่าง (จัดการร้าน/พนักงาน/ยอดขาย)
// WAITER = พนักงานเสิร์ฟ เห็นแค่ผังโต๊ะ (เปิดโต๊ะ/รับออเดอร์/เช็คบิล)
// KITCHEN = ครัว เห็นแค่หน้าครัว (คิว/อัปเดตสถานะอาหาร)
enum StaffRole {
  OWNER
  WAITER
  KITCHEN
}

// ผู้ดูแลแพลตฟอร์ม (เจ้าของระบบ SaaS) — อยู่เหนือทุกร้าน ใช้สร้าง/จัดการร้าน
// แยกจาก Staff โดยสิ้นเชิง (ไม่ผูก shopId) login คนละ cookie/endpoint
model PlatformAdmin {
  id            Int      @id @default(autoincrement())
  username      String   @unique
  passwordHash  String   @map("password_hash")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("platform_admins")
}

// ร้านค้า (tenant) — หนึ่งบัญชี SaaS หนึ่งร้าน มี staff ได้หลายคน
model Shop {
  id          Int        @id @default(autoincrement())
  name        String
  slug        String     @unique // ใช้ทำ URL/subdomain ภายหลัง
  status      ShopStatus @default(pending) // ร้านสมัครเองเริ่มที่ pending, admin สร้างเองตั้ง active
  contactName String?    @map("contact_name") // ชื่อผู้ติดต่อตอนสมัคร (ให้ admin ติดต่อกลับ)
  address     String? // หัวใบเสร็จ — ที่อยู่ร้าน
  phone       String? // หัวใบเสร็จ — เบอร์โทร / เบอร์ติดต่อตอนสมัคร
  taxId       String?    @map("tax_id") // เลขประจำตัวผู้เสียภาษี (ถ้ามี)
  promptpayId String?    @map("promptpay_id") // PromptPay ID (เบอร์/เลขบัตร) สำหรับสร้าง QR รับโอน
  // VAT/Service charge — เก็บอัตราเป็น basis points (700 = 7.00%, 1000 = 10.00%); 0 = ไม่คิด
  vatRate           Int     @default(0) @map("vat_rate") // ภาษีมูลค่าเพิ่ม (basis points)
  vatInclusive      Boolean @default(true) @map("vat_inclusive") // true = ราคาเมนูรวม VAT แล้ว (ถอดออกมาโชว์), false = บวกเพิ่ม
  serviceChargeRate Int     @default(0) @map("service_charge_rate") // เซอร์วิสชาร์จ (basis points)
  // สมาชิก/แต้มสะสม: แต้มที่ได้ต่อ 100 บาท (0 = ปิดระบบสมาชิก); แลกแต้ม 1 แต้ม = 1 บาทเสมอ
  loyaltyEarnRate   Int     @default(0) @map("loyalty_earn_rate")
  // ตัวนับเลขที่ใบเสร็จ/ใบกำกับภาษีแบบรันต่อเนื่องต่อร้าน — increment atomic ตอน checkout
  receiptCounter    Int     @default(0) @map("receipt_counter")
  createdAt   DateTime   @default(now()) @map("created_at")

  staff      Staff[]
  tables     Table[]
  categories Category[]
  menus      Menu[]
  bills      Bill[]
  shifts     Shift[]
  reservations Reservation[]
  members    Member[]
  promotions Promotion[]

  @@map("shops")
}

// โปรโมชันแบบมีกฎ (rule-based) — ร้านตั้งเงื่อนไขเอง ระบบเลือกอันที่เข้าเงื่อนไขให้ตอนเช็คบิล
// เงื่อนไข: ยอดขั้นต่ำ + ช่วงเวลา (happy hour) + วันในสัปดาห์ + เฉพาะสมาชิก/วันเกิด
model Promotion {
  id          Int           @id @default(autoincrement())
  shopId      Int           @map("shop_id")
  name        String
  type        PromotionType
  // ค่าส่วนลด: percent = basis points (1000 = 10%); amount = สตางค์; bogo = ไม่ใช้ (อิง buy/get)
  value       Int           @default(0)
  minSubtotal Int           @default(0) @map("min_subtotal") // ยอดขั้นต่ำ (สตางค์) ถึงใช้ได้, 0 = ไม่จำกัด
  maxDiscount Int?          @map("max_discount") // เพดานส่วนลด (สตางค์) เฉพาะ percent, null = ไม่จำกัด
  // ช่วงเวลา happy hour: นาทีจากเที่ยงคืน 0–1439 (เวลาไทย); null ทั้งคู่ = ทั้งวัน; start>end = ข้ามเที่ยงคืน
  startMinute Int?          @map("start_minute")
  endMinute   Int?          @map("end_minute")
  // วันในสัปดาห์ที่ใช้ได้ (bitmask: bit0=อาทิตย์ … bit6=เสาร์); 127 = ทุกวัน
  daysOfWeek  Int           @default(127) @map("days_of_week")
  // BOGO: ซื้อ buyQty แถม getQty (นับรวมทั้งบิล)
  buyQty      Int           @default(0) @map("buy_qty")
  getQty      Int           @default(0) @map("get_qty")
  membersOnly Boolean       @default(false) @map("members_only") // true = ใช้ได้เฉพาะบิลที่ผูกสมาชิก (ราคาสมาชิก)
  birthdayOnly Boolean      @default(false) @map("birthday_only") // true = ใช้ได้เฉพาะสมาชิกที่วันนี้ตรงวันเกิด
  isActive    Boolean       @default(true) @map("is_active")
  priority    Int           @default(0) // ลำดับเสนอ (สูงกว่ามาก่อน เมื่อส่วนลดเท่ากัน)
  createdAt   DateTime      @default(now()) @map("created_at")

  shop  Shop   @relation(fields: [shopId], references: [id])
  bills Bill[]

  @@index([shopId])
  @@map("promotions")
}

// สมาชิกร้าน (loyalty) — ระบุด้วยเบอร์โทร (unique ต่อร้าน) สะสม/แลกแต้ม
model Member {
  id        Int      @id @default(autoincrement())
  shopId    Int       @map("shop_id")
  phone     String
  name      String?
  birthDate DateTime? @map("birth_date") // วันเกิด (ใช้โปรวันเกิด) — เก็บเฉพาะวันที่, เทียบ วัน/เดือน
  points    Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")

  shop  Shop   @relation(fields: [shopId], references: [id])
  bills Bill[]

  @@unique([shopId, phone])
  @@index([shopId])
  @@map("members")
}

model Table {
  id           Int         @id @default(autoincrement())
  shopId       Int         @map("shop_id")
  tableNumber  String      @map("table_number")
  status       TableStatus @default(vacant)

  shop  Shop   @relation(fields: [shopId], references: [id])
  bills Bill[]
  reservations Reservation[]

  // table_number unique ต่อร้าน (คนละร้านมีโต๊ะเลขเดียวกันได้)
  @@unique([shopId, tableNumber])
  @@index([shopId])
  @@map("tables")
}

model Category {
  id      Int     @id @default(autoincrement())
  shopId  Int     @map("shop_id")
  name    String
  nameEn  String? @map("name_en") // ชื่อแปลอังกฤษ (null = ใช้ name ไทย)
  nameZh  String? @map("name_zh") // ชื่อแปลจีน (null = ใช้ name ไทย)

  shop  Shop   @relation(fields: [shopId], references: [id])
  menus Menu[]

  @@index([shopId])
  @@map("categories")
}

model Menu {
  id           Int      @id @default(autoincrement())
  shopId       Int      @map("shop_id")
  categoryId   Int      @map("category_id")
  name         String
  nameEn       String?  @map("name_en") // ชื่อแปลอังกฤษ (null = ใช้ name ไทย)
  nameZh       String?  @map("name_zh") // ชื่อแปลจีน (null = ใช้ name ไทย)
  price        Int // สตางค์ (combo: ราคาคงที่ของทั้งเซต)
  stockCount   Int?     @map("stock_count") // null = ไม่นับสต็อก (combo: null เสมอ — อิงสต็อกส่วนประกอบ)
  isAvailable  Boolean  @default(true) @map("is_available") // สวิตช์ manual
  isArchived   Boolean  @default(false) @map("is_archived") // soft delete
  isCombo      Boolean  @default(false) @map("is_combo") // true = ชุด/คอมโบ (ราคาคงที่ แตกเป็นส่วนประกอบให้ครัว)
  imageUrl     String?  @map("image_url") // path รูป เช่น /uploads/menus/xxx.jpg (null = ใช้ placeholder)

  shop           Shop            @relation(fields: [shopId], references: [id])
  category       Category        @relation(fields: [categoryId], references: [id])
  orderItems     OrderItem[]
  modifierGroups ModifierGroup[]
  comboComponents  ComboComponent[] @relation("ComboParent") // ถ้าเมนูนี้เป็น combo: รายการในเซต
  usedInCombos     ComboComponent[] @relation("ComboMember") // combo ที่ใช้เมนูนี้เป็นส่วนประกอบ

  @@index([shopId])
  @@index([categoryId])
  @@map("menus")
}

// นิยามส่วนประกอบของชุด/คอมโบ (static set) — combo หนึ่งมีหลายแถว
// comboMenu = เมนูที่ isCombo=true; menu = เมนูจริงที่ต้องทำ/เสิร์ฟ (ห้ามเป็น combo เอง = ไม่ซ้อน)
model ComboComponent {
  id          Int @id @default(autoincrement())
  comboMenuId Int @map("combo_menu_id")
  menuId      Int @map("menu_id")
  quantity    Int @default(1)
  sortOrder   Int @default(0) @map("sort_order")

  comboMenu Menu @relation("ComboParent", fields: [comboMenuId], references: [id])
  menu      Menu @relation("ComboMember", fields: [menuId], references: [id])

  @@index([comboMenuId])
  @@index([menuId])
  @@map("combo_components")
}

// กลุ่มตัวเลือกของเมนู เช่น "ระดับความเผ็ด", "ขนาด", "เพิ่มท็อปปิ้ง" — ผูกกับเมนูโดยตรง
model ModifierGroup {
  id        Int     @id @default(autoincrement())
  menuId    Int     @map("menu_id")
  name      String
  nameEn    String? @map("name_en") // ชื่อแปลอังกฤษ (null = ใช้ name ไทย)
  nameZh    String? @map("name_zh") // ชื่อแปลจีน (null = ใช้ name ไทย)
  // กฎการเลือก: minSelect 0 = ไม่บังคับ, >=1 = บังคับเลือก; maxSelect 1 = เลือกได้ตัวเดียว, >1 = หลายตัว
  minSelect Int    @default(0) @map("min_select")
  maxSelect Int    @default(1) @map("max_select")
  sortOrder Int    @default(0) @map("sort_order")

  menu    Menu             @relation(fields: [menuId], references: [id])
  options ModifierOption[]

  @@index([menuId])
  @@map("modifier_groups")
}

// ตัวเลือกในกลุ่ม เช่น "เผ็ดมาก", "พิเศษ +20" — priceDelta เป็นสตางค์ (บวกเข้าราคาต่อหน่วย)
model ModifierOption {
  id          Int     @id @default(autoincrement())
  groupId     Int     @map("group_id")
  name        String
  nameEn      String? @map("name_en") // ชื่อแปลอังกฤษ (null = ใช้ name ไทย)
  nameZh      String? @map("name_zh") // ชื่อแปลจีน (null = ใช้ name ไทย)
  priceDelta  Int     @default(0) @map("price_delta") // สตางค์ (0 = ไม่บวกเพิ่ม)
  isAvailable Boolean @default(true) @map("is_available")
  sortOrder   Int     @default(0) @map("sort_order")

  group ModifierGroup @relation(fields: [groupId], references: [id])

  @@index([groupId])
  @@map("modifier_options")
}

model Bill {
  id          Int        @id @default(autoincrement())
  shopId         Int            @map("shop_id")
  tableId        Int?           @map("table_id") // null = ออเดอร์กลับบ้าน/เดลิเวอรี (ไม่ผูกโต๊ะ)
  orderType      OrderType      @default(dine_in) @map("order_type")
  // ข้อมูลลูกค้า (เฉพาะ takeaway/delivery)
  customerName    String? @map("customer_name")
  customerPhone   String? @map("customer_phone")
  deliveryAddress String? @map("delivery_address")
  deliveryFee     Int     @default(0) @map("delivery_fee") // สตางค์ ค่าส่ง (บวกท้ายยอดสุทธิ)
  totalPrice     Int?           @map("total_price") // สตางค์, snapshot ยอดสุทธิที่ต้องจ่าย (รวมเซอร์วิส/VAT, หลังหักส่วนลด) ตอน checkout
  discount       Int            @default(0) // สตางค์, ส่วนลดที่ใช้ตอน checkout
  // snapshot การคิดเซอร์วิสชาร์จ/VAT ตอน checkout (กันยอดเพี้ยนเมื่อร้านแก้อัตราภายหลัง)
  serviceCharge     Int     @default(0) @map("service_charge") // สตางค์
  serviceChargeRate Int     @default(0) @map("service_charge_rate") // basis points ที่ใช้
  vatAmount         Int     @default(0) @map("vat_amount") // สตางค์
  vatRate           Int     @default(0) @map("vat_rate") // basis points ที่ใช้
  vatInclusive      Boolean @default(true) @map("vat_inclusive") // โหมด VAT ตอนคิด
  paymentMethod  PaymentMethod? @map("payment_method") // วิธีชำระ (เซ็ตตอน checkout)
  receivedAmount Int?           @map("received_amount") // สตางค์ที่รับมา (เงินสด) — ใช้คำนวณเงินทอน
  shiftId        Int?           @map("shift_id") // กะที่บิลนี้ถูกเช็คบิล (ใช้กระทบยอดเงินสด)
  // สมาชิก/แต้ม (snapshot ตอน checkout)
  memberId        Int? @map("member_id")
  pointsEarned    Int  @default(0) @map("points_earned") // แต้มที่ได้รับจากบิลนี้
  pointsRedeemed  Int  @default(0) @map("points_redeemed") // แต้มที่ใช้แลกส่วนลด (1 แต้ม = 1 บาท)
  // โปรโมชันที่ใช้ตอน checkout (snapshot — เก็บชื่อ+ยอดลด กันโปรถูกแก้/ลบภายหลัง)
  promotionId       Int?    @map("promotion_id")
  promotionName     String? @map("promotion_name") // snapshot ชื่อโปรตอนใช้
  promotionDiscount Int     @default(0) @map("promotion_discount") // สตางค์ ส่วนลดจากโปร (แยกจาก discount=ส่วนลดมือ)
  status         BillStatus     @default(pending)
  // เลขที่ใบเสร็จ/ใบกำกับภาษี — รันต่อเนื่องต่อร้าน (set ตอน checkout), null = ยังไม่ชำระ
  receiptNumber  Int?           @map("receipt_number")
  qrToken        String         @unique @map("qr_token") // UUID (unique ทั้งระบบ)
  createdAt      DateTime       @default(now()) @map("created_at")
  paidAt         DateTime?      @map("paid_at")
  // การคืนเงิน (เซ็ตเมื่อ status -> refunded)
  refundReason   String?        @map("refund_reason")
  refundedAt     DateTime?      @map("refunded_at")
  refundedByName String?        @map("refunded_by_name") // snapshot ชื่อผู้คืนเงิน

  shop            Shop             @relation(fields: [shopId], references: [id])
  table           Table?           @relation(fields: [tableId], references: [id])
  shift           Shift?           @relation(fields: [shiftId], references: [id])
  member          Member?          @relation(fields: [memberId], references: [id])
  promotion       Promotion?       @relation(fields: [promotionId], references: [id])
  orderItems      OrderItem[]
  serviceRequests ServiceRequest[]

  // หนึ่งโต๊ะมี Bill ที่ pending ได้ทีละหนึ่ง (บังคับใน application logic)
  @@index([shopId])
  @@index([tableId])
  @@index([status])
  @@index([paidAt])
  @@index([shiftId])
  @@index([memberId])
  @@index([promotionId])
  // เลขที่ใบเสร็จห้ามซ้ำภายในร้านเดียวกัน (null ซ้ำได้ — บิลที่ยังไม่ชำระ)
  @@unique([shopId, receiptNumber])
  @@map("bills")
}

// กะขาย (cash drawer reconciliation) — เปิดตอนเริ่มกะพร้อมเงินทอนตั้งต้น
// ปิดตอนสิ้นกะพร้อมนับเงินจริง เพื่อกระทบยอด (เงินสดที่ควรมี vs ที่นับได้)
model Shift {
  id                 Int         @id @default(autoincrement())
  shopId             Int         @map("shop_id")
  status             ShiftStatus @default(open)
  openingCash        Int         @default(0) @map("opening_cash") // สตางค์ เงินทอนตั้งต้นในลิ้นชัก
  openedByStaffId    Int         @map("opened_by_staff_id")
  openedByName       String      @map("opened_by_name") // snapshot ชื่อผู้เปิดกะ
  openedAt           DateTime    @default(now()) @map("opened_at")
  closingCashCounted Int?        @map("closing_cash_counted") // สตางค์ ที่นับได้จริงตอนปิดกะ
  closedByStaffId    Int?        @map("closed_by_staff_id")
  closedByName       String?     @map("closed_by_name")
  closedAt           DateTime?   @map("closed_at")
  note               String? // หมายเหตุตอนปิดกะ (อธิบายส่วนต่าง ฯลฯ)

  shop  Shop   @relation(fields: [shopId], references: [id])
  bills Bill[]

  @@index([shopId])
  @@index([status])
  @@map("shifts")
}

// การจองโต๊ะล่วงหน้า — ผูกโต๊ะได้ (optional) สถานะ booked → seated/cancelled
model Reservation {
  id           Int               @id @default(autoincrement())
  shopId       Int               @map("shop_id")
  customerName String            @map("customer_name")
  phone        String?
  partySize    Int               @map("party_size") // จำนวนคน
  reservedAt   DateTime          @map("reserved_at") // วันเวลาที่นัด
  tableId      Int?              @map("table_id") // โต๊ะที่กำหนดไว้ (ถ้ามี)
  note         String?
  status       ReservationStatus @default(booked)
  createdAt    DateTime          @default(now()) @map("created_at")

  shop  Shop   @relation(fields: [shopId], references: [id])
  table Table? @relation(fields: [tableId], references: [id])

  @@index([shopId, reservedAt])
  @@map("reservations")
}

// บันทึกการกระทำสำคัญของพนักงาน (void, คืนเงิน, เช็คบิล, เปิด/ปิดกะ, จัดการพนักงาน ฯลฯ)
// เก็บ snapshot ชื่อผู้ทำ เพื่อให้ประวัติคงอยู่แม้ลบพนักงาน
model AuditLog {
  id        Int      @id @default(autoincrement())
  shopId    Int      @map("shop_id")
  staffId   Int?     @map("staff_id")
  staffName String   @map("staff_name")
  action    String // รหัสการกระทำ เช่น 'bill.refund', 'order.void'
  detail    String? // รายละเอียดอ่านง่าย
  createdAt DateTime @default(now()) @map("created_at")

  @@index([shopId, createdAt])
  @@map("audit_logs")
}

model OrderItem {
  id         Int             @id @default(autoincrement())
  billId     Int             @map("bill_id")
  menuId     Int             @map("menu_id")
  batchId    String          @map("batch_id") // UUID จัดกลุ่ม "รอบการสั่ง"
  quantity   Int
  unitPrice  Int             @map("unit_price") // สตางค์, snapshot ตอนสั่ง
  itemName   String          @map("item_name") // snapshot ชื่อตอนสั่ง
  note       String? // หมายเหตุ/คำขอพิเศษ เช่น "ไม่เผ็ด" "พิเศษ" (ลูกค้า/พนักงานกรอกตอนสั่ง)
  voidReason String?         @map("void_reason") // เหตุผลตอนยกเลิก (เซ็ตตอน status -> voided)
  imageUrl   String?         @map("image_url") // snapshot รูปตอนสั่ง
  status     OrderItemStatus @default(queued)
  createdAt  DateTime        @default(now()) @map("created_at") // เวลาสั่ง
  servedAt   DateTime?       @map("served_at") // เวลาเสิร์ฟ (เซ็ตตอน status -> served)

  bill       Bill @relation(fields: [billId], references: [id])
  menu       Menu @relation(fields: [menuId], references: [id])
  modifiers  OrderItemModifier[]
  comboItems OrderItemComboComponent[] // snapshot ส่วนประกอบ (เฉพาะรายการที่เป็น combo)

  // ผูกร้านผ่าน bill (ไม่เก็บ shop_id ซ้ำ)
  @@index([billId])
  @@index([batchId])
  @@index([status])
  @@map("order_items")
}

// snapshot ส่วนประกอบของ combo ตอนสั่ง — ไว้โชว์ครัว/ใบเสร็จว่าในชุดมีอะไร
// ราคาไม่เก็บ (combo คิดราคาคงที่บน OrderItem.unitPrice แล้ว); mirror แนวคิด OrderItemModifier
model OrderItemComboComponent {
  id          Int    @id @default(autoincrement())
  orderItemId Int    @map("order_item_id")
  menuId      Int?   @map("menu_id") // อ้างต้นทาง (nullable เผื่อเมนูถูกลบภายหลัง)
  name        String // snapshot ชื่อส่วนประกอบ
  quantity    Int    @default(1)

  orderItem OrderItem @relation(fields: [orderItemId], references: [id])

  @@index([orderItemId])
  @@map("order_item_combo_components")
}

// ตัวเลือกที่ลูกค้าเลือกตอนสั่ง — snapshot ชื่อ+ราคา (priceDelta ถูกบวกเข้า OrderItem.unitPrice แล้ว)
// เก็บแยกเพื่อโชว์บนใบเสร็จ/คิวครัว; optionId อ้างต้นทาง (nullable เผื่อ option ถูกลบภายหลัง)
model OrderItemModifier {
  id          Int    @id @default(autoincrement())
  orderItemId Int    @map("order_item_id")
  optionId    Int?   @map("option_id")
  name        String // snapshot ชื่อ เช่น "เผ็ดมาก" หรือ "พิเศษ"
  priceDelta  Int    @default(0) @map("price_delta") // สตางค์ snapshot

  orderItem OrderItem @relation(fields: [orderItemId], references: [id])

  @@index([orderItemId])
  @@map("order_item_modifiers")
}

model Staff {
  id            Int       @id @default(autoincrement())
  shopId        Int       @map("shop_id")
  username      String    @unique // unique ทั้งระบบ = login ตรงโดยไม่ต้องเลือกร้าน
  passwordHash  String    @map("password_hash")
  role          StaffRole @default(OWNER) // staff เดิม/คนแรกของร้าน = OWNER

  shop Shop @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@map("staff")
}

model ServiceRequest {
  id         Int                  @id @default(autoincrement())
  billId     Int                  @map("bill_id")
  type       ServiceRequestType
  status     ServiceRequestStatus @default(pending)
  createdAt  DateTime             @default(now()) @map("created_at")

  bill       Bill @relation(fields: [billId], references: [id])

  // ผูกร้านผ่าน bill
  @@index([billId])
  @@index([status])
  @@map("service_requests")
}
