# Postgres (docker-compose maps container 5432 -> host 5433)
DATABASE_URL="postgresql://posres:posres@localhost:5433/posres?schema=public"

# Auth
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="12h"

# Server (3001 มักชนกับ dev server อื่น จึงใช้ 3333)
PORT=3333
CORS_ORIGIN="http://localhost:5173"

# --- Error tracking (ไม่ตั้ง = ปิด) ---
# SENTRY_DSN="https://xxx@oXXX.ingest.sentry.io/XXX"
# SENTRY_TRACES_SAMPLE_RATE=0

# --- แจ้งเตือน LINE (Messaging API push) — ไม่ตั้ง = ปิด ---
# LINE_CHANNEL_ACCESS_TOKEN="..."
# LINE_TARGET_ID="Uxxxxxxxx หรือ Cxxxxxxxx (group)"

# --- แจ้งเตือน Email (SMTP) — ไม่ตั้ง = ปิด ---
# SMTP_URL="smtps://user:pass@smtp.gmail.com:465"   # หรือใช้ SMTP_HOST/PORT/USER/PASS แยก
# SMTP_FROM="pos@example.com"
# ALERT_EMAIL_TO="owner@example.com"

# --- Frontend (web/.env) ---
# VITE_API_URL=https://<backend>           # origin เฉย ๆ ไม่มี /api
# VITE_SENTRY_DSN=https://xxx@sentry.io/x  # ไม่ตั้ง = ปิด error tracking ฝั่ง web
